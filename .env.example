# Vite (client-side) env vars must start with VITE_
# Copy to `.env` and fill with your own Supabase project values.

# Supabase (client)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY="YOUR_SUPABASE_ANON_KEY"

# Local Supabase (optional — after `supabase start`, copy Publishable / Secret from `supabase status` into `.env.development`)
# VITE_SUPABASE_URL="http://127.0.0.1:54321"
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY="sb_publishable_..."
# SUPABASE_URL="http://127.0.0.1:54321"
# SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# Optional flags
VITE_USE_STATIC_PROJECTS="false"
VITE_SUPABASE_IMAGE_TRANSFORMS="false"

# Node scripts (server-side / local only)
# Never expose the service role key in the browser or commit it.
# For `npm run seed` against remote (or match VITE_ URL for local)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# `npm run seed:admin` — initial admin user (Auth + profiles.is_admin)
# Local: uses Postgres directly (default host/port from VITE_SUPABASE_URL + 54322). Override if needed:
# DB_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
# Remote: SUPABASE_AUTH_SERVICE_ROLE_JWT="eyJ..." (service_role JWT)
# SEED_ADMIN_EMAIL="you@example.com"
# SEED_ADMIN_PASSWORD="choose-a-strong-password"

